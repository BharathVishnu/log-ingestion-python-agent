[
  {
    "regex": "(.+?)",
    "fields": [
      "log_message"
    ]
  },
  {
    "regex": "Email delivery failed for user ([\\w\\.-]+@[\\w\\.-]+)",
    "fields": [
      "event",
      "user"
    ]
  },
  {
